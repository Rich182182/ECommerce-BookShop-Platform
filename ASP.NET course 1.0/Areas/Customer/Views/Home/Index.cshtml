@model IEnumerable<Product>
<div class="row pb-3">
    @foreach(var product in Model)
    {
        <div class="col-lg-3 col-sm-6">
            <div class="row p-2">
                <div class="col-12 p-1">
                    <div class="card border-0 shadow p-3 border-top border-5 rounded">
                        @if (product.ProductImages != null && product.ProductImages.Count() > 1)
                        {
                            <img src="@product.ProductImages.Skip(1).FirstOrDefault().ImageUrl" class="card-img-top rounded"></img>
                        }
                        else if(product.ProductImages != null && product.ProductImages.Count() > 0)
                        {
                        <img src="@product.ProductImages.FirstOrDefault().ImageUrl" class="card-img-top rounded"></img>
                        }
                        else
                        {
                            <img src="https://placehold.co/500x600/png" class="card-img-top rounded" />
                        }           
                        <div class="card-body pb-0"></div>
                        <div class="pl-1">
                            <p class="card-title h5 text-dark opacity-75 text-uppercase text-center">@product.Title</p>
                            <p class="card-title text-warning text-center">by <b>@product.Author</b></p>
                        </div>
                        <p class="text-dark text-opacity-75 text-center mb-0">
                            List Price: <span class="text-decoration-line-through">
                                @product.Price.ToString("c")
                            </span>
                        </p>
                        <p class="text-dark text-opacity-75 text-center">
                            As low as: <span>@product.Price100.ToString("c")</span></p>
                        <div>
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary bg-gradient border-0 form-control">Details</a>
                        </div>
                    </div>
                    
                </div>
                
            </div>
        </div>
    }
</div>